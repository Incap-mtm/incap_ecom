# ── Base de datos ─────────────────────────────────────────
# Desarrollo local (docker-compose)
DB_HOST=localhost
DB_PORT=5435
DB_USER=evershop
DB_PASSWORD=evershop_password
DB_NAME=evershop
DB_SSLMODE=disable

# Railway: usar las variables del plugin PostgreSQL de Railway
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_USER=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_SSLMODE=require

# ── App ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── IA — Asesor Técnico ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Imágenes (producción con Cloudflare R2) ───────────────
# Configurar cuando se migre de almacenamiento local a R2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=incap-media
# R2_PUBLIC_URL=https://media.incap.com.co
